{
  "name": "garak-game",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "description": "Garak :: Game — an English-teaching choose-a-path text RPG by Wrench & Ram",
  "main": "electron/main.cjs",
  "scripts": {
    "selfcheck": "node scripts/selfcheck.js",
    "start": "electron .",
    "pack": "electron-builder --dir",
    "dist": "electron-builder"
  },
  "build": {
    "appId": "com.wrenchandram.garak",
    "productName": "Garak :: Game",
    "copyright": "© Wrench & Ram",
    "files": [
      "src/**/*",
      "campaigns/**/*",
      "electron/**/*",
      "package.json"
    ],
    "directories": {
      "output": "dist"
    },
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "perMachine": false,
      "allowToChangeInstallationDirectory": true
    },
    "publish": [
      {
        "provider": "github",
        "owner": "slinnerb",
        "repo": "GarrakGame"
      }
    ]
  },
  "devDependencies": {
    "electron": "^42.3.3",
    "electron-builder": "^26.8.1"
  },
  "dependencies": {
    "electron-updater": "^6.8.3"
  }
}
